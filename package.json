{
  "name": "portainer-stack-deploy",
  "version": "1.5.0",
  "description": "Github Action to deploy a stack to a Portainer instance",
  "author": "Viet Tien <nvti>",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "actions",
    "node"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.publish.json",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint .",
    "package": "ncc build lib/main.js -o dist --source-map --license licenses.txt",
    "test": "npm run test:ts && npm run test:unit",
    "test:unit": "vitest run",
    "test:ts": "tsc --noEmit",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vercel/ncc": "0.38.4",
    "eslint": "9.39.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-vitest": "0.5.4",
    "js-yaml": "4.1.1",
    "nock": "14.0.11",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
